# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=8000
LOG_LEVEL=INFO
DEFAULT_ENVIRONMENT=prod

# Redis (for ARQ workers; in Docker use service name "redis")
REDIS_HOST=localhost
REDIS_PORT=6379

# ============================================
# STAGE ENVIRONMENT
# ============================================
BASE_URL_STAGE=""
EXPRESS_API_URL_STAGE=""
AWS_ACCESS_KEY_ID_STAGE=your_stage_aws_access_key_id
AWS_SECRET_ACCESS_KEY_STAGE=your_stage_aws_secret_access_key
AWS_STORAGE_BUCKET_NAME_STAGE=your_stage_bucket_name

# ============================================
# PROD ENVIRONMENT
# ============================================
BASE_URL_PROD=""
EXPRESS_API_URL_PROD=""
AWS_ACCESS_KEY_ID_PROD=your_prod_aws_access_key_id
AWS_SECRET_ACCESS_KEY_PROD=your_prod_aws_secret_access_key
AWS_STORAGE_BUCKET_NAME_PROD=your_prod_bucket_name

# ============================================
# SHARED (same across environments)
# ============================================
GEMINI_KEYS=your_gemini_api_key_1,your_gemini_api_key_2
AUTOMATION_BACKEND_URL=""
API_KEY=hanoot-scraper-secure-key-2024
